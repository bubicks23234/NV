# Скопируйте в backend/.env для локального запуска. НЕ коммитьте .env в git.

# === Backend (Render) ===

# Публичный URL бэкенда (без слэша). На Render подставляется автоматически.
WEBAPP_URL=https://nv-api.onrender.com
PUBLIC_SITE_URL=https://novye-tehnologii.ru

# Пароль входа в бота (отправляется в чат после /start)
ADMIN_PASSWORD=change-me-strong-password

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=novtechnologybot
ADMIN_TELEGRAM_IDS=

# Прокси нужен только на российском хостинге. На Render — не задавайте.
# PROXY_URL=http://user:password@host:port

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
AI_WEB_SEARCH=false

# Хранилище заявок
DATA_DIR=/data

# Домены сайта через запятую (для CORS)
CORS_ORIGINS=https://novye-tehnologii.ru,https://ваш-проект.amvera.app

# === Сайт (Amvera) — задайте в панели Amvera при сборке ===
# VITE_API_BASE=https://nv-api.onrender.com
