# Скопируйте в .env и задайте значения. НЕ коммитьте .env в git.

# Публичный URL приложения на Amvera (без слэша в конце)
WEBAPP_URL=https://your-app.amvera.ru
PUBLIC_SITE_URL=https://novye-tehnologii.ru

# Пароль входа в Mini App (только для заказчика)
ADMIN_PASSWORD=change-me-strong-password

# Секрет для JWT-сессий (случайная длинная строка)
JWT_SECRET=change-me-jwt-secret

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=novtechnologybot
# ID чатов администратора через запятую (узнать: @userinfobot)
ADMIN_TELEGRAM_IDS=

# HTTP(S) прокси — обязателен для Telegram API на Amvera
# Формат: http://user:password@host:port
PROXY_URL=http://user:password@host:port

# webhook (по умолчанию) или polling (если webhook не работает)
TELEGRAM_MODE=webhook

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Хранилище заявок (на Amvera монтируется /data)
DATA_DIR=/data

# CORS (для отдельного фронта; при монолите можно оставить *)
CORS_ORIGINS=*
