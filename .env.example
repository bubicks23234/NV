# Скопируйте в .env и задайте значения. НЕ коммитьте .env в git.

# Публичный URL бэкенда на Amvera/Timeweb VPS (без слэша в конце)
# Нужен для webhook Telegram: https://домен/telegram/webhook
WEBAPP_URL=https://your-app.example.com
PUBLIC_SITE_URL=https://novye-tehnologii.ru

# Пароль входа в бота (отправляется в чат после /start)
ADMIN_PASSWORD=change-me-strong-password

# Telegram Bot API
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=novtechnologybot
# ID для уведомлений до первого входа по паролю (через @userinfobot)
ADMIN_TELEGRAM_IDS=

# HTTP(S) прокси — обязателен для Telegram API
# Формат: http://user:password@host:port
PROXY_URL=http://user:password@host:port

# DeepSeek API
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# true — искать в DuckDuckGo (медленнее). false — только DeepSeek
AI_WEB_SEARCH=false

# Хранилище заявок (на Amvera монтируется /data)
DATA_DIR=/data

CORS_ORIGINS=*
